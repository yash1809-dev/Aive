# LLM Provider: ollama (default) or openai
LLM_PROVIDER=ollama
OLLAMA_HOST=http://localhost:11434

# V0 model strategy — two models max
# Extractors (Research, Patent, Startup Analyst): pull with `ollama pull qwen3:8b`
OLLAMA_MODEL_EXTRACTOR=qwen3:8b

# Reasoners (Opportunity Finder, Critic) — Week 3+, not needed yet
# OLLAMA_MODEL_REASONER=deepseek-r1:8b

# Fallback if qwen3 not pulled yet (you have this installed):
# OLLAMA_MODEL_EXTRACTOR=llama3.2

# OpenAI — only if LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

AIVE_DB_PATH=./data/aive.db
